# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/realtime_chat

# JWT
ACCESS_TOKEN_SECRET=change-me-to-a-random-string-at-least-32-chars
REFRESH_TOKEN_SECRET=change-me-to-another-random-string-32-chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=blink
JWT_AUDIENCE=blink-client

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=debug

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=10000

# Frontend
FRONTEND_URL=http://localhost:3000

# Web Push (VAPID)
VAPID_PUBLIC_KEY=BHJUF0RaGCjVZbi9eMMWoVO7-HHCP3-VMp2BwjOFMlJr6XiE8igdCIa-uQ2erPOLdzh0aOGeCU3RBNVoryP1zgo
