FROM oven/bun:1 AS base
WORKDIR /app

COPY package.json bun.lock turbo.json .npmrc ./
COPY packages/ ./packages/
COPY apps/web/ ./apps/web/

RUN bun install
RUN ./node_modules/.bin/turbo run build --filter=web...

FROM oven/bun:1 AS runner
WORKDIR /app
ENV NODE_ENV=production

COPY --from=base /app ./

EXPOSE 3000
CMD ["sh", "-c", "cd apps/web && node /app/node_modules/.bin/next start -p 3000"]
